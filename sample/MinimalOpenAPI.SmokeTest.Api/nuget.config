<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear sources from parent configs, then add the local artifact feed and nuget.org. -->
    <clear />
    <add key="local-artifacts" value="../../artifacts" />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
