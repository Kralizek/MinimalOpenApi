<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear sources from parent configs, then add the local artifact feed and nuget.org. -->
    <clear />
    <add key="local-artifacts" value="../../artifacts" />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!--
      Force all MinimalOpenAPI* packages to be resolved exclusively from the
      local-artifacts feed (the just-packed NuGet artifact).  This prevents
      NuGet from picking a previously-published package from nuget.org that
      happens to have a higher version number than the local development build.
      All other packages (e.g. YamlDotNet, ASP.NET Core) continue to come from
      nuget.org.
    -->
    <packageSource key="local-artifacts">
      <package pattern="MinimalOpenAPI*" />
    </packageSource>
    <packageSource key="nuget">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
